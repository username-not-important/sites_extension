{
  "manifest_version": 3,
  "name": "AvalAI Chat Enhancer",
  "version": "1.0",
  "description": "Custom enhancements for AvalAI Chat",
  "permissions": ["scripting", "activeTab"],
  "content_scripts": [
    {
      "matches": ["https://chat.avalai.ir/chat*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}