{
  "manifest_version": 3,
  "name": "AI Sites Enhancer",
  "version": "1.0",
  "description": "Custom enhancements for supported AI websites",
  "permissions": ["scripting", "activeTab"],
  "content_scripts": [
    {
      "matches": ["https://chat.avalai.ir/chat*"],
      "js": ["content.js", "sites/avalai/content.js"],
      "css": ["sites/avalai/styles.css"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://gapgpt.app/*"],
      "js": ["content.js", "sites/gapgpt/content.js"],
      "css": ["sites/gapgpt/styles.css"],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
